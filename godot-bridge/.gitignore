# Godot editor cache — regenerated on every editor open, never source
.godot/

# Godot 4.4+ ResourceUID sidecars (.uid). Auto-generated by the editor when
# it scans the project; they're per-machine artifacts, not source. We keep
# the addon UID-free to avoid shipping fixed UIDs that could collide in a
# user's project, and to match the godot-v0.3.1 release zip baseline.
*.uid

# Local test scratch artifacts — created when poking at the bridge by hand
test.tscn
_test_*.tres
_test_*.tscn

# OS metadata
.DS_Store
Thumbs.db
